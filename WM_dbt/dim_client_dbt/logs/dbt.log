   AND dp.IS_CURRENT_FLAG = 'Y'
 
INNER JOIN SNOWFLAKE_RND.gold.dim_date dd
    ON v.VALUATION_DATE = dd.DATE_VALUE
 
LEFT JOIN cw
    ON v.CLIENT_ID = cw.CLIENT_ID
   AND v.PLAN_ID = cw.PLAN_ID
        );
