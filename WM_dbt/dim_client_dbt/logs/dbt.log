create or replace transient table SNOWFLAKE_RND.gold.dim_client
         as
        (SELECT


MD5(
    CLIENT_ID || CAST(DBT_VALID_FROM AS STRING)
) AS CLIENT_SK,

CLIENT_ID,
CLIENT_FULL_NAME,
CLIENT_FIRST_NAME,
CLIENT_GENDER,
CLIENT_DATE_OF_BRITH,
CLIENT_DEFAULT_EMAIL,
CLIENT_DEFAULT_MOBILE,
CLIENT_COUNTRY_OF_RESIDENCE,
