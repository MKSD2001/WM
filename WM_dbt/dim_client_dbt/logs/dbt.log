    DBT_VALID_TO,
    '9999-12-31'::TIMESTAMP_NTZ
) AS EFFECTIVE_END_DATE,

CASE
    WHEN DBT_VALID_TO IS NULL THEN 'Y'
    ELSE 'N'
END AS IS_CURRENT_FLAG,
CDC_TIMESTAMP


FROM SNOWFLAKE_RND.gold.dim_client_snapshot
        );
